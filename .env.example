# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# N8N Webhooks (server-side only)
N8N_VIDEO_WEBHOOK=https://your-n8n.cloud/webhook/video-genration
N8N_BLOG_WEBHOOK=https://your-n8n.cloud/webhook/blog-post
N8N_IMAGE_WEBHOOK=https://your-n8n.cloud/webhook/fc-image-post
N8N_SOCIAL_WEBHOOK=https://your-n8n.cloud/webhook/social-post
N8N_VIDEO_APPROVE_WEBHOOK=https://your-n8n.cloud/webhook/video_approve
N8N_BLOG_APPROVE_WEBHOOK=https://your-n8n.cloud/webhook/approve_blog

# Shared secret sent as x-n8n-secret header
N8N_WEBHOOK_SECRET=your_webhook_secret

# Dashboard login (fixed credentials)
DASHBOARD_LOGIN_ID=your_login_id
DASHBOARD_LOGIN_PASSWORD=your_login_password
AUTH_SECRET=long_random_string_used_to_sign_session_cookies
